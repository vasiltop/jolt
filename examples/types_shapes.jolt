module types_shapes;
import "./math/geometry.jolt";

struct MyStruct {
    field1: i32;
    field2: *geometry:Vector;
    field3: **i64;
}

enum ShapeKind {
    Field1,
    Field2,
}

fn use_vec(val: *geometry:Vector) *i32 {
    let k = ShapeKind::Field1;
    let x: *i32 = null;
    let y = x as *i64;
    ret x;
}
