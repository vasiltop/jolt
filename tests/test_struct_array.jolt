module tests;
import "./common.jolt";

struct Data {
    values: [i32; 3];
    id: i32;
}

fn main() i32 {
    let d = Data {
        values: [10, 20, 30],
        id: 42
    };

    common:assert(d.values[0] == 10);
    common:assert(d.values[1] == 20);
    common:assert(d.values[2] == 30);
    common:assert(d.id == 42);

    d.values[1] = 99;
    common:assert(d.values[1] == 99);

    ret 0;
}
